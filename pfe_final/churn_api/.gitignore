# =============================================================================
# .gitignore — Fichiers et dossiers à exclure du dépôt Git
# =============================================================================

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ── Environnements virtuels ──────────────────────────────────────────────────
venv/
env/
ENV/
.venv/

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Tests / Coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Système ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Variables d'environnement ────────────────────────────────────────────────
.env
.env.local

# ── Fichiers temporaires Python ──────────────────────────────────────────────
*.pkl.bak
*.tmp

# ── ATTENTION : ne PAS exclure fastapi_artifacts/ ────────────────────────────
# Les artefacts du modèle DOIVENT être versionnés pour que le projet soit
# reproductible. C'est un cas particulier — normalement les .pkl sont gitignorés.
# !fastapi_artifacts/
# !fastapi_artifacts/*.pkl
# !fastapi_artifacts/*.json
# !fastapi_artifacts/*.csv